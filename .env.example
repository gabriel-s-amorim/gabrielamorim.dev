# Copie este arquivo para .env e preencha os valores reais.
# Nunca commite o .env — ele já está no .gitignore.

# --- Banco de dados (Neon / Supabase Postgres) -----------------------------
# Neon: crie um projeto em https://console.neon.tech, copie a "Connection
# string" (modo "Pooled connection" funciona bem com o runtime serverless
# da Vercel). Formato:
# postgresql://usuario:senha@host.neon.tech/nome_do_banco?sslmode=require
DATABASE_URL=""

# --- Auth.js -----------------------------------------------------------------
# Gere um valor aleatório forte, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ou, com a CLI do Auth.js instalada: npx auth secret
AUTH_SECRET=""

# --- Usuário admin (usado apenas por prisma/seed.ts) ------------------------
# Depois do primeiro seed, você pode remover ADMIN_PASSWORD do seu .env
# local por segurança — ele só é lido no momento do seed, nunca em runtime.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
